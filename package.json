{
  "name": "react-atom-trigger",
  "version": "2.0.7",
  "description": "Geometry-based scroll trigger for React with precise enter/leave control. A modern alternative to react-waypoint.",
  "keywords": [
    "intersection",
    "observer",
    "on-scroll",
    "react",
    "scroll",
    "scroll-into-view",
    "v2"
  ],
  "homepage": "https://atomtrigger.dev",
  "bugs": {
    "url": "https://github.com/innrvoice/react-atom-trigger/issues"
  },
  "license": "MIT",
  "author": "Pavel Bochkov-Rastopchin <hello@visiofutura.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/innrvoice/react-atom-trigger.git"
  },
  "files": [
    "lib",
    "MIGRATION.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/index.js",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "typings": "./lib/index.d.ts",
  "unpkg": "./lib/index.umd.js",
  "jsdelivr": "./lib/index.umd.js",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:sb": "pnpm build-storybook",
    "deploy:storybook": "pnpm build:sb",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --ignore-pattern node_modules --ignore-pattern lib",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "preview:sb": "pnpm build:sb && npx serve -s storybook-static -l 3000",
    "start:storybook": "node scripts/serve-storybook.mjs",
    "precommit:checks": "pnpm format:check && pnpm lint && pnpm test",
    "test": "pnpm test:all",
    "test:all": "pnpm test:unit && pnpm test:storybook",
    "test:coverage": "pnpm test:coverage:unit",
    "test:coverage:unit": "vitest run --project=unit --reporter=verbose --coverage.enabled=true --coverage.reportsDirectory=coverage/unit",
    "test:coverage:storybook": "vitest run --project=storybook --coverage.enabled=true --coverage.reportsDirectory=coverage/storybook",
    "test:package-smoke": "node scripts/package-smoke.mjs",
    "test:react-compat": "node scripts/react-compat-smoke.mjs",
    "test:react-compat:matrix": "node scripts/react-compat-matrix.mjs",
    "test:unit": "vitest run --project=unit --reporter=verbose",
    "test:watch": "vitest --project=unit",
    "test:storybook": "vitest run --project=storybook",
    "storybook": "storybook dev",
    "build-storybook": "storybook build -o storybook-static"
  },
  "devDependencies": {
    "@codecov/rollup-plugin": "^1.9.1",
    "@storybook/addon-docs": "10.3.4",
    "@storybook/addon-vitest": "10.3.4",
    "@storybook/react-vite": "10.3.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.6.3",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.50.0",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "storybook": "10.3.4",
    "tsdown": "^0.21.7",
    "tslib": "^2.8.0",
    "typescript": "^5.6.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "pnpm": {
    "overrides": {
      "@actions/github>undici": "7.24.7",
      "@actions/http-client>undici": "7.24.7",
      "picomatch": "^4.0.4"
    }
  }
}
